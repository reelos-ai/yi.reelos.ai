{
  "name": "yijing-cosmos",
  "version": "1.1.0",
  "description": "Three.js 周易观卦应用，支持本地 Grok CLI 与自备 AI 模型",
  "author": "ReelOS.AI",
  "license": "MIT",
  "homepage": "https://yi.reelos.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/reelos-ai/yi.reelos.ai.git"
  },
  "bugs": "https://github.com/reelos-ai/yi.reelos.ai/issues",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "node server.mjs",
    "desktop": "electron .",
    "icon": "swift scripts/generate-icon.swift",
    "build:mac": "electron-builder --mac dir --arm64 --publish never && npm run sign:mac && node scripts/create-dmg.mjs",
    "build:win": "electron-builder --win nsis --x64 --publish never",
    "sign:mac": "codesign --force --deep --sign - \"dist/mac-arm64/周易宇宙观卦.app\""
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "ai.reelos.yijing-cosmos",
    "productName": "周易宇宙观卦",
    "asar": true,
    "files": [
      "index.html",
      "server.mjs",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.lifestyle",
      "icon": "assets/icon.icns",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "yijing-cosmos-${version}-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "周易宇宙观卦"
    }
  }
}
